function doPost(e) {
  var data = JSON.parse(e.postData.contents);
  
  var ss = SpreadsheetApp.openById("ID Google Sheet");
  var sh = ss.getSheetByName("Sheet1");

  sh.appendRow([
    data.timestamp,
    data.epoch,
    data.distance,
    data.status
  ]);

  return ContentService
    .createTextOutput("OK")
    .setMimeType(ContentService.MimeType.TEXT);
}
